# Copy to .env.local and fill in values from the Supabase dashboard:
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# football-data.org — sign up at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-football-data-api-key

# Cron secret for /api/results. Generate via: openssl rand -hex 32
# Required for the results sync route to accept Vercel Cron (or curl) calls.
CRON_SECRET=your-cron-secret
